#!/bin/bash
# ask-tty — stdin proxy for Claude Code
#
# Always uses local file IPC (~/.cache/ask-tty/).
# Optionally ALSO notifies a remote service (for Telegram push etc.)
# Response can come from either channel — whoever replies first wins.
#
# Usage:
#   ask-tty "Enter sudo password" --sensitive
#   echo $(ask-tty "sudo password" -s) | sudo -S <cmd>

ASK_DIR="$HOME/.cache/ask-tty"
PROMPT=""
SENSITIVE=false
TIMEOUT=120

while [ $# -gt 0 ]; do
  case "$1" in
    --sensitive|-s) SENSITIVE=true ;;
    --timeout|-t) shift; TIMEOUT="$1" ;;
    *) [ -n "$PROMPT" ] && PROMPT="$PROMPT $1" || PROMPT="$1" ;;
  esac
  shift
done

if [ -z "$PROMPT" ]; then
  echo "Usage: ask-tty \"prompt\" [--sensitive] [--timeout seconds]" >&2
  exit 1
fi

# Kill all background jobs on exit
trap 'kill $(jobs -p) 2>/dev/null' EXIT

# --- Setup local file IPC (always) ---
mkdir -p "$ASK_DIR"
echo "$PROMPT" > "$ASK_DIR/pending"
[ "$SENSITIVE" = true ] && touch "$ASK_DIR/sensitive"
rm -f "$ASK_DIR/response"

# --- Optionally notify remote service (non-blocking) ---
CONFIG_FILE="${ASK_TTY_CONFIG:-$HOME/.config/ask-tty/config}"
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
  if [ -n "$ASK_TTY_URL" ] && [ -n "$ASK_TTY_SECRET" ]; then
    TIMEOUT_MS=$(( TIMEOUT * 1000 ))
    PAYLOAD=$(jq -n --arg p "$PROMPT" --arg s "$ASK_TTY_SECRET" --argjson sens "$SENSITIVE" --argjson t "$TIMEOUT_MS" '{prompt:$p,secret:$s,sensitive:$sens,timeout:$t}' 2>/dev/null)
    if [ -n "$PAYLOAD" ]; then
      # Fully detach so it doesn't block script exit
      (curl -s -X POST "$ASK_TTY_URL" -H 'Content-Type: application/json' --max-time $(( TIMEOUT + 5 )) -d "$PAYLOAD" | jq -r '.reply // empty' 2>/dev/null | while read -r line; do
        if [ -n "$line" ] && [ ! -f "$ASK_DIR/response" ]; then
          echo "$line" > "$ASK_DIR/response"
        fi
      done) </dev/null >/dev/null 2>&1 &
      disown
    fi
  fi
fi

# --- Poll for response (from hook or remote) ---
START=$(date +%s)
while true; do
  if [ -f "$ASK_DIR/response" ]; then
    REPLY=$(cat "$ASK_DIR/response")
    rm -f "$ASK_DIR/response" "$ASK_DIR/pending" "$ASK_DIR/sensitive"
    printf '%s' "$REPLY"
    exit 0
  fi
  NOW=$(date +%s)
  if (( NOW - START >= TIMEOUT )); then break; fi
  sleep 0.1
done

rm -f "$ASK_DIR/pending" "$ASK_DIR/sensitive"
echo "Error: timed out ($TIMEOUT s)" >&2
exit 1
