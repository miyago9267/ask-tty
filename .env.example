# Shared secret for authenticating ask-tty requests
# Generate with: openssl rand -hex 16
ASK_TTY_SECRET=

# Port for the HTTP server
WEBHOOK_PORT=3847

# Notification adapter: 'telegram' or leave empty for web-only (/pending + /respond)
ASK_TTY_ADAPTER=

# --- Telegram adapter (only if ASK_TTY_ADAPTER=telegram) ---

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send a message to the bot, check server logs)
OWNER_CHAT_ID=

# Public webhook URL
WEBHOOK_URL=https://your-server.com/telegram/webhook
