# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send a message to the bot, check server logs)
OWNER_CHAT_ID=

# Shared secret for authenticating ask-tty requests
# Generate with: openssl rand -hex 16
ASK_TTY_SECRET=

# Webhook URL (your public-facing URL)
WEBHOOK_URL=https://your-server.com/telegram/webhook

# Port for the HTTP server
WEBHOOK_PORT=3847
