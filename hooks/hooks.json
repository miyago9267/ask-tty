{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/tty-respond.sh",
            "timeout": 10
          }
        ],
        "description": "Intercept /tty <input> — sends input to ask-tty service without entering Claude context"
      }
    ]
  }
}
